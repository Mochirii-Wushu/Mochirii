{
  "name": "mochirii-shopify-theme",
  "private": true,
  "version": "0.6.0",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "22.x",
    "npm": ">=10 <11"
  },
  "scripts": {
    "check": "npm run scan:brand-boundaries && npm run check:migration-manifest && npm run check:prepayment-config && npm run check:contract-tests && npm run check:generic-tooling && npm run check:sbom && npm run check:theme-js && npm run theme:check",
    "scan:brand-boundaries": "node ../../scripts/check-brand-boundaries.mjs",
    "generate:migration-manifest": "node scripts/generate-migration-manifest.mjs",
    "check:migration-manifest": "node scripts/check-migration-manifest.mjs",
    "check:prepayment-config": "npm run check:release-safety && npm run check:approved-copy && npm run check:product-facts && npm run check:launch-content-contracts && npm run check:customer-facing-copy",
    "check:release-safety": "node scripts/check-release-safety.mjs",
    "check:approved-copy": "node scripts/check-approved-customer-copy.mjs",
    "check:product-facts": "node scripts/check-product-facts.mjs",
    "gate:product-facts": "node scripts/check-product-facts.mjs --require-complete",
    "check:launch-content-contracts": "node scripts/check-launch-content-contracts.mjs",
    "gate:launch-content-contracts": "node scripts/check-launch-content-contracts.mjs --require-launch-ready",
    "check:customer-facing-copy": "node scripts/check-customer-facing-copy.mjs",
    "check:contract-tests": "node --test scripts/product-facts-contract.test.mjs scripts/private-price-rule.test.mjs scripts/launch-content-contracts.test.mjs scripts/prepayment-evidence-gate.test.mjs",
    "verify:private-prices": "node scripts/verify-private-prices.mjs",
    "gate:prepayment-complete": "node scripts/check-prepayment-evidence.mjs",
    "check:payment-dependent": "node scripts/check-payment-dependent-boundary.mjs",
    "check:generic-tooling": "node --test scripts/shopify-filter-metafield-csv.test.mjs scripts/shopify-product-copy-csv.test.mjs",
    "check:sbom": "node scripts/check-sbom.mjs",
    "check:theme-js": "node --check assets/mochirii-theme.js",
    "theme:check": "shopify theme check",
    "theme:package": "shopify theme package"
  },
  "devDependencies": {
    "@shopify/cli": "4.5.1"
  }
}
