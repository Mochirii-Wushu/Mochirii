{% assign catalog_collection = collections['mochirii-cosmetics'] %}
{% assign catalog_url = routes.all_products_collection_url | default: '/collections/all' %}
{% if catalog_collection != blank and catalog_collection.products_count > 0 %}
  {% assign catalog_url = catalog_collection.url %}
{% endif %}

<section class="collection-header">
  <div class="section-inner collection-header__grid">
    <div>
      <p class="eyebrow">Mochirii Cosmetics</p>
      <h1>{{ collection.title | escape }}</h1>
      {% if collection.description != blank %}
        <div class="rte lede">{{ collection.description }}</div>
      {% endif %}
    </div>
    <aside class="collection-summary" aria-label="Collection summary">
      <strong>{{ collection.products_count }}</strong>
      <span>{% if collection.products_count == 1 %}product{% else %}products{% endif %}</span>
    </aside>
  </div>
</section>

<section class="section section-soft">
  <div class="section-inner">
    <nav class="category-pills category-pills--compact" aria-label="Collection navigation">
      <a href="{{ catalog_url | escape }}">Shop all</a>
      <a href="{{ routes.collections_url | escape }}">Collections</a>
      <span aria-current="page">{{ collection.title | escape }}</span>
    </nav>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    {% assign active_filter_count = 0 %}
    {% for filter in collection.filters %}
      {% assign filter_contract = filter.param_name | append: '|' | append: filter.type %}
      {% assign is_allowed_filter = false %}
      {% case filter_contract %}
        {% when 'filter.v.availability|boolean', 'filter.v.price|price_range', 'filter.p.m.custom.product_type|list', 'filter.p.m.custom.skin_type|list', 'filter.p.m.custom.appearance_concerns|list', 'filter.p.m.custom.routine_step|list', 'filter.p.m.custom.key_ingredients|list' %}
          {% assign is_allowed_filter = true %}
      {% endcase %}
      {% if is_allowed_filter %}
        {% assign active_filter_count = active_filter_count | plus: filter.active_values.size %}
        {% if filter.type == 'price_range' %}
          {% if filter.min_value.value or filter.max_value.value %}
            {% assign active_filter_count = active_filter_count | plus: 1 %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endfor %}

    <form id="shop-filters" class="collection-controls" method="get" action="{{ collection.url | escape }}">
      <div class="field collection-sort">
        <label for="SortBy-{{ section.id | escape }}">Sort</label>
        {% assign current_sort = collection.sort_by | default: collection.default_sort_by %}
        <select id="SortBy-{{ section.id | escape }}" name="sort_by">
          {% for option in collection.sort_options %}
            <option value="{{ option.value | escape }}" {% if option.value == current_sort %}selected="selected"{% endif %}>{{ option.name | escape }}</option>
          {% endfor %}
        </select>
      </div>

      {% for filter in collection.filters %}
        {% assign filter_contract = filter.param_name | append: '|' | append: filter.type %}
        {% assign is_allowed_filter = false %}
        {% case filter_contract %}
          {% when 'filter.v.availability|boolean', 'filter.v.price|price_range', 'filter.p.m.custom.product_type|list', 'filter.p.m.custom.skin_type|list', 'filter.p.m.custom.appearance_concerns|list', 'filter.p.m.custom.routine_step|list', 'filter.p.m.custom.key_ingredients|list' %}
            {% assign is_allowed_filter = true %}
        {% endcase %}
        {% if is_allowed_filter %}
          <details class="collection-filter">
          <summary>
            {{ filter.label | escape }}
            {% if filter.active_values.size > 0 %}<span>({{ filter.active_values.size }})</span>{% endif %}
          </summary>
          <div class="collection-filter__options">
            {% case filter.type %}
              {% when 'boolean' %}
                {% if filter.true_value %}
                  <label class="filter-option" for="Filter-{{ filter.param_name | handle | escape }}-true">
                    <input
                      id="Filter-{{ filter.param_name | handle | escape }}-true"
                      type="checkbox"
                      name="{{ filter.param_name | escape }}"
                      value="{{ filter.true_value.value | escape }}"
                      {% if filter.true_value.active %}checked="checked"{% endif %}
                      {% if filter.true_value.count == 0 and filter.true_value.active == false %}disabled="disabled"{% endif %}
                    >
                    <span>{{ filter.true_value.label | escape }} ({{ filter.true_value.count }})</span>
                  </label>
                {% endif %}
                {% if filter.false_value %}
                  <label class="filter-option" for="Filter-{{ filter.param_name | handle | escape }}-false">
                    <input
                      id="Filter-{{ filter.param_name | handle | escape }}-false"
                      type="checkbox"
                      name="{{ filter.param_name | escape }}"
                      value="{{ filter.false_value.value | escape }}"
                      {% if filter.false_value.active %}checked="checked"{% endif %}
                      {% if filter.false_value.count == 0 and filter.false_value.active == false %}disabled="disabled"{% endif %}
                    >
                    <span>{{ filter.false_value.label | escape }} ({{ filter.false_value.count }})</span>
                  </label>
                {% endif %}
              {% when 'list' %}
                {% for value in filter.values %}
                  <label class="filter-option" for="Filter-{{ filter.param_name | handle | escape }}-{{ forloop.index }}">
                    <input
                      id="Filter-{{ filter.param_name | handle | escape }}-{{ forloop.index }}"
                      type="checkbox"
                      name="{{ value.param_name | escape }}"
                      value="{{ value.value | escape }}"
                      {% if value.active %}checked="checked"{% endif %}
                      {% if value.count == 0 and value.active == false %}disabled="disabled"{% endif %}
                    >
                    <span>{{ value.label | escape }} ({{ value.count }})</span>
                  </label>
                {% endfor %}
              {% when 'price_range' %}
                <div class="price-filter">
                  <div class="field">
                    <label for="Filter-{{ filter.min_value.param_name | handle | escape }}">Minimum</label>
                    <input
                      id="Filter-{{ filter.min_value.param_name | handle | escape }}"
                      type="number"
                      name="{{ filter.min_value.param_name | escape }}"
                      value="{% if filter.min_value.value %}{{ filter.min_value.value | money_without_currency | replace: ',', '' | escape }}{% endif %}"
                      min="0"
                      step="0.01"
                      max="{{ filter.range_max | money_without_currency | replace: ',', '' | escape }}"
                      inputmode="decimal"
                    >
                  </div>
                  <div class="field">
                    <label for="Filter-{{ filter.max_value.param_name | handle | escape }}">Maximum</label>
                    <input
                      id="Filter-{{ filter.max_value.param_name | handle | escape }}"
                      type="number"
                      name="{{ filter.max_value.param_name | escape }}"
                      value="{% if filter.max_value.value %}{{ filter.max_value.value | money_without_currency | replace: ',', '' | escape }}{% endif %}"
                      min="0"
                      step="0.01"
                      max="{{ filter.range_max | money_without_currency | replace: ',', '' | escape }}"
                      inputmode="decimal"
                    >
                  </div>
                </div>
            {% endcase %}
          </div>
          </details>
        {% endif %}
      {% endfor %}

      <div class="collection-controls__actions">
        <button class="button" type="submit">Apply</button>
        {% if active_filter_count > 0 %}<a class="text-link" href="{{ collection.url | escape }}">Clear filters</a>{% endif %}
      </div>
    </form>

    {% paginate collection.products by 24 %}
      {% if collection.products_count > 0 %}
        <div id="collection-products" class="product-grid" role="list">
          {% for product in collection.products %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>
        {% if paginate.pages > 1 %}
          <nav class="pagination" aria-label="Collection pagination">{{ paginate | default_pagination }}</nav>
        {% endif %}
      {% else %}
        <div class="empty-state empty-state--wide">
          <h2>{{ settings.empty_catalog_heading | escape }}</h2>
          <p>{{ settings.empty_catalog_body | escape }}</p>
          <a class="button button--secondary" href="{{ catalog_url | escape }}">Shop all</a>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
