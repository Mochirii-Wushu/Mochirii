{% assign selected_variant = product.selected_or_first_available_variant %}
{% assign catalog_collection = collections['mochirii-cosmetics'] %}
{% assign catalog_url = routes.all_products_collection_url | default: '/collections/all' %}
{% if catalog_collection != blank and catalog_collection.products_count > 0 %}
  {% assign catalog_url = catalog_collection.url %}
{% endif %}
{% assign faq_page = pages['faq'] %}

{% assign functional_identity = product.metafields.custom.functional_identity.value | strip %}
{% assign card_benefit = product.metafields.custom.card_benefit.value | strip %}
{% assign benefits = product.metafields.custom.benefits.value %}
{% assign volume_facts = product.metafields.custom.volume.value %}
{% assign volume_display = volume_facts.display | strip %}
{% assign skin_types = product.metafields.custom.skin_type.value %}
{% assign appearance_concerns = product.metafields.custom.appearance_concerns.value %}
{% assign routine_step = product.metafields.custom.routine_step.value | strip %}
{% assign usage_directions = product.metafields.custom.usage_directions.value %}
{% assign usage_text = usage_directions.text | strip %}
{% assign usage_frequency = usage_directions.frequency | strip %}
{% assign usage_amount = usage_directions.amount | strip %}
{% assign usage_timing = usage_directions.routine_timing %}
{% assign usage_rinse_behavior = usage_directions.rinse_behavior | strip %}
{% assign key_ingredient_details = product.metafields.custom.key_ingredient_details.value %}
{% assign ingredients_inci = product.metafields.custom.ingredients_inci.value | strip %}
{% assign warnings = product.metafields.custom.warnings.value %}
{% assign warning_text = warnings.text | strip %}
{% assign warning_incompatibilities = warnings.incompatibilities %}
{% assign show_warnings = false %}
{% if warnings.review_result == 'label-matched' and warning_text != blank %}
  {% assign show_warnings = true %}
{% endif %}
{% assign texture = product.metafields.custom.texture.value | strip %}
{% assign finish = product.metafields.custom.finish.value | strip %}
{% assign fragrance_status = product.metafields.custom.fragrance_status.value | strip %}
{% assign country_of_origin = product.metafields.custom.country_of_origin.value | strip %}
{% assign package_details = product.metafields.custom.package_details.value | strip %}
{% assign certifications = product.metafields.custom.certifications.value %}
{% assign certification_items = certifications.items %}
{% assign show_certifications = false %}
{% if certifications.review_result == 'verified-wording' and certification_items != blank %}
  {% assign show_certifications = true %}
{% endif %}
{% assign complementary_products = product.metafields.custom.complementary_products.value %}

<nav class="breadcrumbs section-inner" aria-label="Breadcrumb">
  <ol role="list">
    <li><a href="{{ routes.root_url | escape }}">Home</a></li>
    <li><a href="{{ catalog_url | escape }}">Shop</a></li>
    <li aria-current="page">{{ product.title | escape }}</li>
  </ol>
</nav>

<section class="product-layout section-inner" data-product-section data-product-url="{{ product.url | escape }}">
  <div class="product-gallery">
    {% if product.media.size > 0 %}
      <div class="product-media-list" tabindex="0" aria-label="Product media carousel">
        {% for media in product.media limit: 6 %}
          {% assign product_media_alt = media.alt | strip %}
          <div
            id="ProductMedia-{{ section.id }}-{{ forloop.index }}"
            class="product-media"
            data-product-media-id="{{ media.id }}"
          >
            {% if forloop.first %}
              {{ media.preview_image | image_url: width: 1400 | image_tag: loading: 'eager', fetchpriority: 'high', alt: product_media_alt, sizes: '(min-width: 1080px) 48vw, 100vw' }}
            {% else %}
              {{ media.preview_image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: product_media_alt, sizes: '(min-width: 1080px) 48vw, 100vw' }}
            {% endif %}
            {% unless media.media_type == 'image' %}
              <span class="media-type-badge">{{ media.media_type | replace: '_', ' ' | escape }}</span>
            {% endunless %}
          </div>
        {% endfor %}
      </div>
      {% if product.media.size > 1 %}
        <nav class="product-thumbnails" aria-label="Choose product media">
          {% for media in product.media limit: 6 %}
            <a
              class="product-thumbnail"
              href="#ProductMedia-{{ section.id }}-{{ forloop.index }}"
              data-product-media-link
              data-media-id="{{ media.id }}"
              aria-label="View {{ product.title | escape }} media {{ forloop.index }}"
            >
              {% assign thumbnail_alt = media.alt | strip %}
              {{ media.preview_image | image_url: width: 260 | image_tag: loading: 'lazy', alt: thumbnail_alt, sizes: '120px' }}
            </a>
          {% endfor %}
        </nav>
      {% endif %}
    {% else %}
      <div class="product-media product-media--empty">
        <span class="media-placeholder">
          <span>{{ product.title | escape }}</span>
          <small>Product image unavailable.</small>
        </span>
      </div>
    {% endif %}
  </div>

  <div class="product-details">
    <div class="product-title-block">
      <div class="product-kicker">
        {% if routine_step != blank %}<span>{{ routine_step | escape }}</span>{% endif %}
        <span data-product-availability>{% if selected_variant.available %}In stock{% else %}Out of stock{% endif %}</span>
      </div>
      <p class="eyebrow">Mochirii Cosmetics</p>
      <h1>{{ product.title | escape }}</h1>
      {% if functional_identity != blank %}
        <p class="product-functional-identity">{{ functional_identity | escape }}</p>
      {% endif %}
      {% if card_benefit != blank %}
        <p class="product-primary-benefit">{{ card_benefit | escape }}</p>
      {% endif %}
      <div class="product-purchase-summary">
        <p class="price price--large" data-product-price>{{ selected_variant.price | money }}</p>
        {% if volume_display != blank %}<p class="product-size"><span>Size</span> {{ volume_display | escape }}</p>{% endif %}
      </div>
      <p class="visually-hidden" data-product-variant-status aria-live="polite" aria-atomic="true"></p>
    </div>

    {% form 'product', product, class: 'product-form product-purchase' %}
      {% if form.errors %}
        <div class="form-message" role="alert">We could not add this product. Review your selection and try again.</div>
      {% endif %}

      {% if product.variants.size > 1 %}
        <div class="field">
          <label for="Variant-{{ section.id }}">Variant</label>
          <select id="Variant-{{ section.id }}" name="id" data-product-variant-select>
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                data-price="{{ variant.price | money | escape }}"
                data-available="{{ variant.available }}"
                data-media-id="{{ variant.featured_media.id }}"
                {% if variant == selected_variant %}selected="selected"{% endif %}
                {% unless variant.available %}disabled="disabled"{% endunless %}
              >
                {{ variant.title | escape }}{% unless variant.available %} - Out of stock{% endunless %}
              </option>
            {% endfor %}
          </select>
        </div>
      {% else %}
        <input type="hidden" name="id" value="{{ selected_variant.id }}">
      {% endif %}

      <div class="product-form__row">
        <div class="field field--quantity">
          <label for="Quantity-{{ section.id }}">Quantity</label>
          <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1" data-product-quantity {% unless selected_variant.available %}disabled="disabled"{% endunless %}>
        </div>
        <button class="button" type="submit" name="add" data-add-to-cart {% unless selected_variant.available %}disabled="disabled"{% endunless %}>
          {% if selected_variant.available %}Add to cart{% else %}Out of stock{% endif %}
        </button>
      </div>
    {% endform %}

    <div class="product-accordions" aria-label="Product information">
      {% if benefits != blank %}
        <details open>
          <summary>What it does</summary>
          <ul class="product-fact-list">
            {% for benefit in benefits limit: 3 %}<li>{{ benefit | escape }}</li>{% endfor %}
          </ul>
        </details>
      {% endif %}
      {% if skin_types != blank or appearance_concerns != blank %}
        <details {% if benefits == blank %}open{% endif %}>
          <summary>Best for</summary>
          <dl class="product-detail-list">
            {% if skin_types != blank %}
              <div>
                <dt>Skin type</dt>
                <dd>{{ skin_types | join: ', ' | escape }}</dd>
              </div>
            {% endif %}
            {% if appearance_concerns != blank %}
              <div>
                <dt>Appearance concerns</dt>
                <dd>{{ appearance_concerns | join: ', ' | escape }}</dd>
              </div>
            {% endif %}
          </dl>
        </details>
      {% endif %}
      {% if usage_text != blank or usage_frequency != blank or usage_amount != blank or usage_timing != blank or usage_rinse_behavior != blank %}
        <details {% if benefits == blank and skin_types == blank and appearance_concerns == blank %}open{% endif %}>
          <summary>How to use</summary>
          {% if usage_text != blank %}<p>{{ usage_text | escape | newline_to_br }}</p>{% endif %}
          <dl class="product-detail-list">
            {% if usage_frequency != blank %}<div><dt>Frequency</dt><dd>{{ usage_frequency | escape }}</dd></div>{% endif %}
            {% if usage_amount != blank %}<div><dt>Amount</dt><dd>{{ usage_amount | escape }}</dd></div>{% endif %}
            {% if usage_timing != blank %}<div><dt>Routine timing</dt><dd>{{ usage_timing | join: ', ' | escape }}</dd></div>{% endif %}
            {% if usage_rinse_behavior != blank %}<div><dt>Rinse behavior</dt><dd>{{ usage_rinse_behavior | escape }}</dd></div>{% endif %}
          </dl>
        </details>
      {% endif %}
      {% if key_ingredient_details != blank %}
        <details>
          <summary>Key ingredients</summary>
          <ul class="product-fact-list">
            {% for ingredient in key_ingredient_details %}
              {% assign ingredient_name = ingredient.name | strip %}
              {% assign ingredient_role = ingredient.cosmetic_role | strip %}
              {% if ingredient_name != blank and ingredient_role != blank %}
                <li><strong>{{ ingredient_name | escape }}</strong> — {{ ingredient_role | escape }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        </details>
      {% endif %}
      {% if ingredients_inci != blank %}
        <details>
          <summary>Full ingredients (INCI)</summary>
          <p>{{ ingredients_inci | escape }}</p>
        </details>
      {% endif %}
      {% if show_warnings %}
        <details>
          <summary>Warnings and compatibility</summary>
          <p>{{ warning_text | escape | newline_to_br }}</p>
          {% if warning_incompatibilities != blank %}
            <ul class="product-fact-list">
              {% for incompatibility in warning_incompatibilities %}<li>{{ incompatibility | escape }}</li>{% endfor %}
            </ul>
          {% endif %}
        </details>
      {% endif %}
      {% if texture != blank or finish != blank or fragrance_status != blank %}
        <details>
          <summary>Texture, finish, and fragrance</summary>
          <dl class="product-detail-list">
            {% if texture != blank %}<div><dt>Texture</dt><dd>{{ texture | escape }}</dd></div>{% endif %}
            {% if finish != blank %}<div><dt>Finish</dt><dd>{{ finish | escape }}</dd></div>{% endif %}
            {% if fragrance_status != blank %}<div><dt>Fragrance</dt><dd>{{ fragrance_status | escape }}</dd></div>{% endif %}
          </dl>
        </details>
      {% endif %}
      {% if country_of_origin != blank or package_details != blank or show_certifications %}
        <details>
          <summary>Origin, package, and certifications</summary>
          <dl class="product-detail-list">
            {% if country_of_origin != blank %}<div><dt>Country of manufacture</dt><dd>{{ country_of_origin | escape }}</dd></div>{% endif %}
            {% if package_details != blank %}<div><dt>Package</dt><dd>{{ package_details | escape | newline_to_br }}</dd></div>{% endif %}
            {% if show_certifications %}<div><dt>Product certifications</dt><dd>{{ certification_items | join: ', ' | escape }}</dd></div>{% endif %}
          </dl>
        </details>
      {% endif %}
      {% if shop.shipping_policy != blank or shop.refund_policy != blank or faq_page != blank %}
        <details>
          <summary>Shipping, returns, and help</summary>
          <ul class="product-service-links">
            {% if shop.shipping_policy != blank %}<li><a href="{{ shop.shipping_policy.url | escape }}">Shipping</a></li>{% endif %}
            {% if shop.refund_policy != blank %}<li><a href="{{ shop.refund_policy.url | escape }}">Returns</a></li>{% endif %}
            {% if faq_page != blank %}<li><a href="{{ faq_page.url | escape }}">Frequently asked questions</a></li>{% endif %}
          </ul>
        </details>
      {% endif %}
    </div>
  </div>
</section>

{% if complementary_products != blank %}
  <section class="section section-soft product-recommendations" aria-labelledby="RoutineCompanions-{{ section.id }}">
    <div class="section-inner">
      <div class="section-head section-head--split">
        <div>
          <p class="eyebrow">Build your routine</p>
          <h2 id="RoutineCompanions-{{ section.id }}">Mochirii routine companions</h2>
        </div>
        <a class="text-link" href="{{ catalog_url | escape }}">Shop skincare</a>
      </div>
      <div class="product-grid product-grid--compact" role="list" aria-label="Mochirii Cosmetics routine companions">
        {% for related_product in complementary_products limit: 4 %}
          {% unless related_product.id == product.id %}
            {% render 'product-card', product: related_product %}
          {% endunless %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
