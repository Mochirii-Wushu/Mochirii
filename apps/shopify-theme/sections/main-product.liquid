{% assign selected_variant = product.selected_or_first_available_variant %}
{% assign volume = product.metafields.custom.volume %}
{% assign skin_type = product.metafields.custom.skin_type %}
{% assign key_ingredients = product.metafields.custom.key_ingredients %}
{% assign aroma = product.metafields.custom.aroma %}
{% assign usage_directions = product.metafields.custom.usage_directions %}
{% assign ingredients_inci = product.metafields.custom.ingredients_inci %}
{% if ingredients_inci == blank %}
  {% assign ingredients_inci = product.metafields.custom.materials %}
{% endif %}
{% assign warnings = product.metafields.custom.warnings %}
{% assign country_of_origin = product.metafields.custom.country_of_origin %}
{% assign certifications = product.metafields.custom.certifications %}
{% assign routine_step = product.metafields.custom.routine_step %}
{% assign replenishment_interval = product.metafields.custom.replenishment_interval %}

{% assign routine_collection = blank %}
{% for product_collection in product.collections %}
  {% if product_collection.handle == 'cleanse-tone' or product_collection.handle == 'hydrate-barrier' or product_collection.handle == 'brighten-smooth' or product_collection.handle == 'age-support-nourish' %}
    {% assign routine_collection = product_collection %}
    {% break %}
  {% endif %}
{% endfor %}
{% if routine_collection == blank %}
  {% assign routine_collection = collections['mochirii-cosmetics'] %}
{% endif %}

{% assign description_text = product.description | strip_html | downcase %}
{% assign legacy_brand_token = 'vele' | append: 'sari' %}
{% assign supplier_token = 'self' | append: 'named' %}
{% assign supplier_spaced_token = 'self' | append: ' named' %}
{% assign private_label_token = 'private' | append: ' label' %}
{% assign fulfillment_token = 'drop' | append: 'shipping' %}
{% assign customer_offer_token = 'offer your' | append: ' customers' %}
{% assign professional_token = 'professional' | append: ' skincare' %}
{% assign inflated_token = 'ultimate' | append: ' solution' %}
{% assign exclusive_token = 'exclu' | append: 'sive' %}
{% assign customer_empower_token = 'empower your' | append: ' customers' %}
{% assign description_needs_review = false %}
{% if description_text contains legacy_brand_token or description_text contains supplier_token or description_text contains supplier_spaced_token or description_text contains private_label_token or description_text contains fulfillment_token or description_text contains customer_offer_token or description_text contains professional_token or description_text contains inflated_token or description_text contains exclusive_token or description_text contains customer_empower_token %}
  {% assign description_needs_review = true %}
{% endif %}

<section class="product-layout section-inner" data-product-section data-product-url="{{ product.url }}">
  <div class="product-gallery">
    {% if product.media.size > 0 %}
      <div class="product-media-list" tabindex="0" aria-label="Product media carousel">
        {% for media in product.media limit: 6 %}
          {% assign product_media_alt = media.alt | default: product.title %}
          <div
            id="ProductMedia-{{ section.id }}-{{ forloop.index }}"
            class="product-media"
            data-product-media-id="{{ media.id }}"
          >
            {% if forloop.first %}
              {{ media.preview_image | image_url: width: 1400 | image_tag: loading: 'eager', fetchpriority: 'high', alt: product_media_alt, sizes: '(min-width: 1080px) 48vw, 100vw' }}
            {% else %}
              {{ media.preview_image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: product_media_alt, sizes: '(min-width: 1080px) 48vw, 100vw' }}
            {% endif %}
            {% unless media.media_type == 'image' %}
              <span class="media-type-badge">{{ media.media_type | replace: '_', ' ' }}</span>
            {% endunless %}
          </div>
        {% endfor %}
      </div>
      {% if product.media.size > 1 %}
        <nav class="product-thumbnails" aria-label="Choose product media">
          {% for media in product.media limit: 6 %}
            <a
              class="product-thumbnail"
              href="#ProductMedia-{{ section.id }}-{{ forloop.index }}"
              data-product-media-link
              data-media-id="{{ media.id }}"
              aria-label="View {{ product.title | escape }} media {{ forloop.index }}"
            >
              {% assign thumbnail_alt = media.alt | default: product.title %}
              {{ media.preview_image | image_url: width: 260 | image_tag: loading: 'lazy', alt: thumbnail_alt, sizes: '120px' }}
            </a>
          {% endfor %}
        </nav>
      {% endif %}
    {% else %}
      <div class="product-media product-media--empty">
        <span class="media-placeholder">
          <span>{{ product.title }}</span>
          <small>Product image unavailable.</small>
        </span>
      </div>
    {% endif %}
  </div>

  <div class="product-details">
    <div class="product-title-block">
      <div class="product-kicker">
        <span>{{ routine_step | metafield_text | default: product.type | default: 'Skincare' }}</span>
        <span data-product-availability>{% if selected_variant.available %}In stock{% else %}Sold out{% endif %}</span>
      </div>
      <p class="eyebrow">Mochirii Cosmetics</p>
      <h1>{{ product.title }}</h1>
      <p class="price price--large" data-product-price>{{ selected_variant.price | money }}</p>
    </div>

    {% if volume != blank or skin_type != blank or key_ingredients != blank %}
      <dl class="product-quick-facts" aria-label="Product quick facts">
        {% if volume != blank %}
          <div><dt>Size</dt><dd>{{ volume | metafield_text }}</dd></div>
        {% endif %}
        {% if skin_type != blank %}
          <div><dt>Suitable for</dt><dd>{{ skin_type | metafield_text }}</dd></div>
        {% endif %}
        {% if key_ingredients != blank %}
          <div><dt>Key ingredients</dt><dd>{{ key_ingredients | metafield_text }}</dd></div>
        {% endif %}
      </dl>
    {% endif %}

    {% form 'product', product, class: 'product-form product-purchase' %}
      {% if form.errors %}
        <div class="form-message" role="alert">{{ form.errors | default_errors }}</div>
      {% endif %}

      {% if product.variants.size > 1 %}
        <div class="field">
          <label for="Variant-{{ section.id }}">Variant</label>
          <select id="Variant-{{ section.id }}" name="id" data-product-variant-select>
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                data-price="{{ variant.price | money | escape }}"
                data-available="{{ variant.available }}"
                data-media-id="{{ variant.featured_media.id }}"
                {% if variant == selected_variant %}selected="selected"{% endif %}
                {% unless variant.available %}disabled="disabled"{% endunless %}
              >
                {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
              </option>
            {% endfor %}
          </select>
        </div>
      {% else %}
        <input type="hidden" name="id" value="{{ selected_variant.id }}">
      {% endif %}

      <div class="product-form__row">
        <div class="field field--quantity">
          <label for="Quantity-{{ section.id }}">Quantity</label>
          <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1" data-product-quantity {% unless selected_variant.available %}disabled="disabled"{% endunless %}>
        </div>
        <button class="button" type="submit" name="add" data-add-to-cart {% unless selected_variant.available %}disabled="disabled"{% endunless %}>
          {% if selected_variant.available %}Add to cart{% else %}Sold out{% endif %}
        </button>
      </div>
    {% endform %}

    <div class="product-accordions" aria-label="Product information">
      {% if product.description != blank and description_needs_review == false %}
        <details open>
          <summary>Description</summary>
          <div class="rte product-description">{{ product.description }}</div>
        </details>
      {% endif %}
      {% if usage_directions != blank %}
        <details {% if product.description == blank or description_needs_review %}open{% endif %}>
          <summary>How to use</summary>
          <p>{{ usage_directions | metafield_text }}</p>
        </details>
      {% endif %}
      {% if ingredients_inci != blank %}
        <details>
          <summary>Full ingredients (INCI)</summary>
          <p>{{ ingredients_inci | metafield_text }}</p>
        </details>
      {% endif %}
      <details>
        <summary>Warnings</summary>
        {% if warnings != blank %}
          <p>{{ warnings | metafield_text }}</p>
        {% else %}
          <p>Warning information is not available on this page. Review the product label before use.</p>
        {% endif %}
      </details>
      {% if country_of_origin != blank or certifications != blank %}
        <details>
          <summary>Origin and certifications</summary>
          {% if country_of_origin != blank %}<p><strong>Origin:</strong> {{ country_of_origin | metafield_text }}</p>{% endif %}
          {% if certifications != blank %}<p><strong>Product certifications:</strong> {{ certifications | metafield_text }}</p>{% endif %}
        </details>
      {% endif %}
      {% if aroma != blank or replenishment_interval != blank %}
        <details>
          <summary>Texture and routine</summary>
          {% if aroma != blank %}<p><strong>Aroma:</strong> {{ aroma | metafield_text }}</p>{% endif %}
          {% if replenishment_interval != blank %}<p><strong>Replenishment:</strong> {{ replenishment_interval | metafield_text }}</p>{% endif %}
        </details>
      {% endif %}
      {% if shop.shipping_policy != blank or shop.refund_policy != blank %}
        <details>
          <summary>Shipping and returns</summary>
          <p>
            {% if shop.shipping_policy != blank %}<a href="{{ shop.shipping_policy.url }}">Shipping policy</a>{% endif %}
            {% if shop.shipping_policy != blank and shop.refund_policy != blank %} &middot; {% endif %}
            {% if shop.refund_policy != blank %}<a href="{{ shop.refund_policy.url }}">Refund policy</a>{% endif %}
          </p>
        </details>
      {% endif %}
    </div>

    {% if routine_collection != blank and routine_collection.products_count > 1 %}
      <div class="product-recommendations">
        <div class="section-head section-head--split">
          <div>
            <p class="eyebrow">Complete your routine</p>
            <h2>{{ routine_collection.title }}</h2>
          </div>
          <a class="text-link" href="{{ routine_collection.url }}">View collection</a>
        </div>
        <div class="product-grid product-grid--compact" role="list">
          {% for related_product in routine_collection.products limit: 5 %}
            {% unless related_product.id == product.id %}
              {% render 'product-card', product: related_product %}
            {% endunless %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
