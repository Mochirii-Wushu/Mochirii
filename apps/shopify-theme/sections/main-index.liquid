{% assign catalog_collection = collections['mochirii-cosmetics'] %}
{% if section.settings.featured_collection != blank %}
  {% assign catalog_collection = section.settings.featured_collection %}
{% endif %}
{% if catalog_collection == blank or catalog_collection.products_count == 0 %}
  {% assign catalog_collection = collections.all %}
{% endif %}

{% assign catalog_url = routes.all_products_collection_url | default: '/collections/all' %}
{% if catalog_collection != blank and catalog_collection.products_count > 0 %}
  {% assign catalog_url = catalog_collection.url %}
{% endif %}
{% assign product_type_url = catalog_url | append: '#shop-filters' %}
{% assign skin_needs_url = catalog_url | append: '#shop-filters' %}
{% assign routine_url = routes.collections_url | append: '#routine-collections' %}
{% assign contact_page = pages['contact'] %}

{% assign hero_image = section.settings.hero_image %}
{% assign hero_alt = section.settings.hero_image_alt | strip %}

<section class="hero hero--storefront">
  <div class="hero--storefront__media">
    {% if hero_image != blank and hero_alt != blank %}
      {{ hero_image | image_url: width: 2200 | image_tag: loading: 'eager', fetchpriority: 'high', alt: hero_alt, sizes: '100vw' }}
    {% else %}
      <img src="{{ 'mochirii-page-password.webp' | asset_url }}" alt="Abstract green Mochirii Cosmetics artwork." width="1440" height="528" loading="eager" fetchpriority="high">
    {% endif %}
  </div>
  <div class="section-inner hero--storefront__content">
    <p class="eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
    <h1>{{ section.settings.hero_heading | escape }}</h1>
    <p class="lede">{{ section.settings.hero_text | escape }}</p>
    <div class="button-row">
      {% assign primary_link = section.settings.primary_cta_link | default: catalog_url %}
      <a class="button" href="{{ primary_link | escape }}">{{ section.settings.primary_cta_label | escape }}</a>
      <a class="button button--secondary" href="{{ routes.collections_url | escape }}">Browse collections</a>
    </div>
  </div>
</section>

<section class="section" id="product-discovery" aria-labelledby="ProductDiscoveryHeading-{{ section.id }}">
  <div class="section-inner">
    <div class="section-head section-head--split">
      <div>
        <p class="eyebrow">Find your products</p>
        <h2 id="ProductDiscoveryHeading-{{ section.id }}">Shop by product, skin need, or routine step</h2>
      </div>
      <a class="text-link" href="{{ catalog_url | escape }}">Shop all skincare</a>
    </div>
    <ul class="discovery-grid" role="list">
      <li>
        <a class="discovery-card" href="{{ product_type_url | escape }}">
          <span>Product type</span>
          <strong>Compare skincare formats</strong>
          <small>Use product filters to compare cleansers, serums, moisturizers, facial oils, eye care, and exfoliating products.</small>
        </a>
      </li>
      <li>
        <a class="discovery-card" href="{{ skin_needs_url | escape }}">
          <span>Skin needs</span>
          <strong>Filter by skin type and appearance concern</strong>
          <small>Narrow the catalog by skin suitability and appearance concern.</small>
        </a>
      </li>
      <li>
        <a class="discovery-card" href="{{ routine_url | escape }}">
          <span>Routine</span>
          <strong>Choose products by routine step</strong>
          <small>Browse cleansing products, hydrating serums, moisturizers, and facial oils by routine step.</small>
        </a>
      </li>
    </ul>
  </div>
</section>

<section class="section" id="featured-products">
  <div class="section-inner">
    <div class="section-head section-head--split">
      <div>
        <p class="eyebrow">Featured skincare</p>
        <h2>{{ section.settings.featured_heading | escape }}</h2>
      </div>
      <a class="text-link" href="{{ catalog_url | escape }}">Shop all</a>
    </div>

    {% if catalog_collection != blank and catalog_collection.products_count > 0 %}
      <div class="product-grid product-grid--featured" role="list" aria-label="Featured Mochirii Cosmetics products">
        {% for product in catalog_collection.products limit: 6 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state empty-state--wide">
        <h2>{{ settings.empty_catalog_heading | escape }}</h2>
        <p>{{ settings.empty_catalog_body | escape }}</p>
      </div>
    {% endif %}
  </div>
</section>

<section class="section section-soft" id="routine-collections">
  <div class="section-inner">
    <div class="section-head">
      <p class="eyebrow">Shop by routine</p>
      <h2>{{ section.settings.collections_heading | escape }}</h2>
    </div>

    <div class="collection-grid collection-grid--four">
      {% assign routine_handles = 'cleanse-tone,hydrate-barrier,brighten-smooth,age-support-nourish' | split: ',' %}
      {% assign routine_titles = 'Cleanse & Tone,Hydrate & Barrier,Brighten & Smooth,Age-Support & Nourish' | split: ',' %}
      {% for routine_handle in routine_handles %}
        {% assign routine_collection = collections[routine_handle] %}
        {% assign routine_title = routine_titles[forloop.index0] %}
        {% assign routine_url = catalog_url %}
        {% if routine_collection != blank %}
          {% assign routine_url = routine_collection.url %}
        {% endif %}
        {% assign routine_image = routine_collection.image %}

        <article class="collection-card">
          <a class="collection-card__image" href="{{ routine_url | escape }}" aria-label="{{ routine_title | escape }}">
            {% if routine_image != blank %}
              {% assign routine_alt = routine_image.alt | strip %}
              {{ routine_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: routine_alt, sizes: '(min-width: 1080px) 25vw, (min-width: 720px) 50vw, 100vw' }}
            {% else %}
              <span class="media-placeholder">
                <span>{{ routine_title | escape }}</span>
                <small>Product image unavailable.</small>
              </span>
            {% endif %}
          </a>
          <div class="collection-card__body">
            <p class="product-card__line">Routine step</p>
            <h3><a href="{{ routine_url | escape }}">{{ routine_title | escape }}</a></h3>
            {% if routine_collection != blank and routine_collection.description != blank %}
              <div class="rte">{{ routine_collection.description }}</div>
            {% endif %}
            {% if routine_collection != blank %}
              <p class="collection-count">{{ routine_collection.products_count }} products</p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section product-standards">
  <div class="section-inner proof-grid">
    <div class="proof-copy">
      <p class="eyebrow">Product details</p>
      <h2>{{ section.settings.standards_heading | escape }}</h2>
      <p class="section-intro">{{ section.settings.standards_intro | escape }}</p>
    </div>
    <div class="proof-list" role="list" aria-label="Mochirii Cosmetics product details">
      <div role="listitem">
        <span>01</span>
        <h3>{{ section.settings.standard_one_heading | escape }}</h3>
        <p>{{ section.settings.standard_one_text | escape }}</p>
      </div>
      <div role="listitem">
        <span>02</span>
        <h3>{{ section.settings.standard_two_heading | escape }}</h3>
        <p>{{ section.settings.standard_two_text | escape }}</p>
      </div>
      <div role="listitem">
        <span>03</span>
        <h3>{{ section.settings.standard_three_heading | escape }}</h3>
        <p>{{ section.settings.standard_three_text | escape }}</p>
      </div>
    </div>
  </div>
</section>

<section class="section store-reassurance" aria-labelledby="StoreReassuranceHeading-{{ section.id }}">
  <div class="section-inner">
    <div class="section-head">
      <p class="eyebrow">Before you order</p>
      <h2 id="StoreReassuranceHeading-{{ section.id }}">Shipping, returns, and product support</h2>
      <p class="section-intro">{{ section.settings.policy_note | escape }}</p>
    </div>
    <div class="reassurance-grid">
      {% if shop.shipping_policy != blank %}
        <article>
          <h3>Shipping</h3>
          <p>Review available destinations, costs, processing, and delivery estimates.</p>
          <a class="text-link" href="{{ shop.shipping_policy.url | escape }}">Read shipping details</a>
        </article>
      {% endif %}
      {% if shop.refund_policy != blank %}
        <article>
          <h3>Returns</h3>
          <p>Check return eligibility, time limits, and instructions before ordering.</p>
          <a class="text-link" href="{{ shop.refund_policy.url | escape }}">Read return details</a>
        </article>
      {% endif %}
      {% if contact_page != blank %}
        <article>
          <h3>Product support</h3>
          <p>Ask Mochirii Cosmetics about product information or an existing order.</p>
          <a class="text-link" href="{{ contact_page.url | escape }}">Contact Mochirii Cosmetics</a>
        </article>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Storefront",
  "settings": [
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured collection"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Branded product hero image"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Hero image alt text (required when image is set)"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero eyebrow",
      "default": "Skincare by routine"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero heading",
      "default": "Mochirii Cosmetics"
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Hero text",
      "default": "Find cleansers, serums, moisturizers, and facial oils for each step of your routine."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary button label",
      "default": "Shop skincare"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Featured products heading",
      "default": "Start your routine here"
    },
    {
      "type": "text",
      "id": "collections_heading",
      "label": "Collections heading",
      "default": "Choose your next step"
    },
    {
      "type": "text",
      "id": "standards_heading",
      "label": "Standards heading",
      "default": "See what fits your routine"
    },
    {
      "type": "textarea",
      "id": "standards_intro",
      "label": "Standards introduction",
      "default": "Compare texture, skin suitability, key ingredients, directions, and full ingredient lists before you choose."
    },
    {
      "type": "text",
      "id": "standard_one_heading",
      "label": "First standard heading",
      "default": "Matching product images"
    },
    {
      "type": "textarea",
      "id": "standard_one_text",
      "label": "First standard text",
      "default": "Each gallery shows the Mochirii Cosmetics packaging for that product."
    },
    {
      "type": "text",
      "id": "standard_two_heading",
      "label": "Second standard heading",
      "default": "Ingredients and directions"
    },
    {
      "type": "textarea",
      "id": "standard_two_text",
      "label": "Second standard text",
      "default": "Find key ingredients, full INCI, size, skin suitability, and directions on every product page."
    },
    {
      "type": "text",
      "id": "standard_three_heading",
      "label": "Third standard heading",
      "default": "Shopping details in one place"
    },
    {
      "type": "textarea",
      "id": "standard_three_text",
      "label": "Third standard text",
      "default": "Check warnings, origin, shipping, and returns before adding a product to your routine."
    },
    {
      "type": "textarea",
      "id": "policy_note",
      "label": "Policy note",
      "default": "Shipping and return details are available before checkout."
    }
  ]
}
{% endschema %}
