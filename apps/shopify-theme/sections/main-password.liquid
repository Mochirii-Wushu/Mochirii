<section class="password-page">
  <img class="password-page__art" src="{{ 'mochirii-page-password.webp' | asset_url }}" alt="" width="1440" height="560" loading="eager">
  <div class="section-inner password-page__inner">
    <div class="password-panel">
      <a class="brand" href="{{ routes.root_url | escape }}" aria-label="Mochirii Cosmetics storefront home">
        <span class="brand-mark brand-mark--image" aria-hidden="true">
          <img src="{{ 'mochirii-emblem.webp' | asset_url }}" alt="" width="56" height="56" loading="eager">
        </span>
        <span class="brand-wording">
          <span class="brand-text">Mochirii Cosmetics</span>
          <span class="brand-subtext">Skincare</span>
        </span>
      </a>

      <div class="section-head">
        <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h1>{{ section.settings.heading | escape }}</h1>
        <p class="section-intro">{{ section.settings.intro | escape }}</p>
      </div>

      {% form 'storefront_password', class: 'password-form' %}
        {% if form.errors %}
          <div class="form-message" role="alert">
            The password did not match. Try again.
          </div>
        {% endif %}

        <div class="field">
          <label for="Password-{{ section.id | escape }}">Password</label>
          <input id="Password-{{ section.id | escape }}" type="password" name="password" autocomplete="current-password">
        </div>
        <button class="button" type="submit">Enter storefront</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Mochirii Cosmetics"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The skincare shop is opening soon."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Enter the password to preview the store."
    }
  ]
}
{% endschema %}
