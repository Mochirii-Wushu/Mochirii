<footer class="site-footer">
  {% assign launch_collection_url = routes.root_url %}
  {% comment %} release-safety:publication:start {% endcomment %}
  {% if settings.product_publication_approved %}
    {% assign launch_collection_url = routes.all_products_collection_url | default: '/collections/all' %}
    {% assign launch_collection = collections['mochirii-cosmetics'] %}
    {% if launch_collection != blank and launch_collection.products_count > 0 %}
      {% assign launch_collection_url = launch_collection.url %}
    {% endif %}
  {% endif %}
  {% comment %} release-safety:publication:end {% endcomment %}
  {% assign contact_url = routes.root_url | append: 'pages/contact' %}
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a class="brand footer-brand" href="{{ routes.root_url }}" aria-label="{{ settings.brand_display_name | default: 'Mochirii Cosmetics' }} skin care storefront home">
        <span class="brand-mark brand-mark--image" aria-hidden="true">
          <img src="{{ 'mochirii-emblem.webp' | asset_url }}" alt="" width="56" height="56" loading="lazy">
        </span>
        <span class="brand-wording">
          <span class="brand-text">{{ settings.brand_display_name | default: 'Mochirii Cosmetics' }}</span>
          <span class="brand-subtext">Skin Care</span>
        </span>
      </a>
      <p class="footer-note">{{ section.settings.summary_text | default: settings.footer_summary }}</p>
      {% if settings.corporate_display_name != blank %}
        <p class="footer-note footer-note--fine">Customer care, policies, and legal notices are handled by {{ settings.corporate_display_name }}.</p>
      {% endif %}
    </div>

    <div class="footer-nav-groups">
      <nav class="footer-links" aria-label="Footer navigation">
        <h2>Store</h2>
        {% if settings.product_publication_approved and section.settings.footer_menu != blank and section.settings.footer_menu.links.size > 0 %}
          {% for link in section.settings.footer_menu.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% else %}
          <a href="{{ routes.root_url }}">Storefront home</a>
          {% if settings.product_publication_approved %}
            <a href="{{ launch_collection_url }}">Shop all</a>
            <a href="{{ routes.collections_url }}">Collections</a>
          {% endif %}
          <a href="{{ contact_url }}">Contact</a>
        {% endif %}
      </nav>

      <nav class="footer-links" aria-label="Policy navigation">
        <h2>Policies</h2>
        {% if shop.shipping_policy != blank %}
          <a href="{{ shop.shipping_policy.url }}">Shipping policy</a>
        {% endif %}
        {% if shop.refund_policy != blank %}
          <a href="{{ shop.refund_policy.url }}">Refund policy</a>
        {% endif %}
        {% if shop.privacy_policy != blank %}
          <a href="{{ shop.privacy_policy.url }}">Privacy policy</a>
        {% endif %}
        {% if shop.terms_of_service != blank %}
          <a href="{{ shop.terms_of_service.url }}">Terms of service</a>
        {% endif %}
        <a href="https://mochirii.com" rel="noopener">Guild site</a>
      </nav>
    </div>
  </div>

  {% if settings.corporate_display_name != blank %}
    <div class="site-footer__bottom">
      <div class="section-inner">
        <p>&copy; {{ 'now' | date: '%Y' }} {{ settings.corporate_display_name }}. All rights reserved.</p>
      </div>
    </div>
  {% endif %}
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "summary_text",
      "label": "Summary text",
      "default": "Skin care arranged by routine, with product details close at hand."
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu"
    }
  ]
}
{% endschema %}
