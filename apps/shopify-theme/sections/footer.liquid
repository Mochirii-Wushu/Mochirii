<footer class="site-footer">
  {% assign contact_page = pages['contact'] %}
  {% assign faq_page = pages['faq'] %}
  {% assign about_page = pages['about'] %}
  {% assign ingredients_page = pages['ingredients-standards'] %}
  {% assign accessibility_page = pages['accessibility'] %}
  {% assign support_menu = section.settings.footer_menu %}
  {% if support_menu == blank %}
    {% assign support_menu = linklists['footer'] %}
  {% endif %}
  {% assign privacy_choices_url = blank %}
  {% if support_menu != blank and support_menu.links.size > 0 %}
    {% for link in support_menu.links %}
      {% assign privacy_link_handle = link.title | handleize %}
      {% if link.url != blank %}
        {% if privacy_link_handle == 'privacy-choices' or privacy_link_handle == 'your-privacy-choices' or privacy_link_handle == 'do-not-sell-or-share-my-personal-information' or privacy_link_handle == 'do-not-sell-or-share-my-personal-data' %}
          {% assign privacy_url_prefix = link.url | slice: 0 %}
          {% assign privacy_url_protocol_relative = link.url | slice: 0, 2 %}
          {% assign privacy_url_encoded = link.url | url_encode | upcase %}
          {% assign privacy_url_downcase = link.url | downcase %}
          {% if privacy_url_prefix == '/' and privacy_url_protocol_relative != '//' %}
            {% unless privacy_url_encoded contains '%5C' or privacy_url_downcase contains '%5c' %}
              {% assign privacy_choices_url = link.url %}
              {% break %}
            {% endunless %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endif %}
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a class="brand footer-brand" href="{{ routes.root_url | escape }}" aria-label="Mochirii Cosmetics skincare storefront home">
        <span class="brand-mark brand-mark--image" aria-hidden="true">
          <img src="{{ 'mochirii-emblem.webp' | asset_url }}" alt="" width="56" height="56" loading="lazy">
        </span>
        <span class="brand-wording">
          <span class="brand-text">Mochirii Cosmetics</span>
          <span class="brand-subtext">Skincare</span>
        </span>
      </a>
      <p class="footer-note">{{ section.settings.summary_text | default: settings.footer_summary | escape }}</p>
      {% if contact_page != blank %}<p class="footer-note footer-note--fine">Questions about a product or order? <a href="{{ contact_page.url | escape }}">Contact Mochirii Cosmetics.</a></p>{% endif %}
      <a class="footer-guild-link" href="https://mochirii.com" rel="noopener noreferrer">Visit Mochirii Guild</a>
    </div>

    <div class="footer-nav-groups">
      {% assign support_link_count = 0 %}
      {% if contact_page != blank %}{% assign support_link_count = support_link_count | plus: 1 %}{% endif %}
      {% if faq_page != blank %}{% assign support_link_count = support_link_count | plus: 1 %}{% endif %}
      {% if about_page != blank %}{% assign support_link_count = support_link_count | plus: 1 %}{% endif %}
      {% if ingredients_page != blank %}{% assign support_link_count = support_link_count | plus: 1 %}{% endif %}
      {% if accessibility_page != blank %}{% assign support_link_count = support_link_count | plus: 1 %}{% endif %}
      {% if support_link_count > 0 %}
      <nav class="footer-links" aria-label="Footer navigation">
        <h2>Support</h2>
        {% if contact_page != blank %}<a href="{{ contact_page.url | escape }}">Contact</a>{% endif %}
        {% if faq_page != blank %}<a href="{{ faq_page.url | escape }}">FAQ</a>{% endif %}
        {% if about_page != blank %}<a href="{{ about_page.url | escape }}">About</a>{% endif %}
        {% if ingredients_page != blank %}<a href="{{ ingredients_page.url | escape }}">Ingredients &amp; Standards</a>{% endif %}
        {% if accessibility_page != blank %}<a href="{{ accessibility_page.url | escape }}">Accessibility</a>{% endif %}
      </nav>
      {% endif %}

      {% assign policy_link_count = 0 %}
      {% if shop.shipping_policy != blank %}{% assign policy_link_count = policy_link_count | plus: 1 %}{% endif %}
      {% if shop.refund_policy != blank %}{% assign policy_link_count = policy_link_count | plus: 1 %}{% endif %}
      {% if shop.privacy_policy != blank %}{% assign policy_link_count = policy_link_count | plus: 1 %}{% endif %}
      {% if shop.terms_of_service != blank %}{% assign policy_link_count = policy_link_count | plus: 1 %}{% endif %}
      {% if privacy_choices_url != blank %}{% assign policy_link_count = policy_link_count | plus: 1 %}{% endif %}
      {% if policy_link_count > 0 %}
      <nav class="footer-links" aria-label="Policy navigation">
        <h2>Policies</h2>
        {% if shop.shipping_policy != blank %}<a href="{{ shop.shipping_policy.url | escape }}">Shipping</a>{% endif %}
        {% if shop.refund_policy != blank %}<a href="{{ shop.refund_policy.url | escape }}">Returns</a>{% endif %}
        {% if shop.privacy_policy != blank %}<a href="{{ shop.privacy_policy.url | escape }}">Privacy</a>{% endif %}
        {% if shop.terms_of_service != blank %}<a href="{{ shop.terms_of_service.url | escape }}">Terms</a>{% endif %}
        {% if privacy_choices_url != blank %}<a href="{{ privacy_choices_url | escape }}">Privacy Choices</a>{% endif %}
      </nav>
      {% endif %}
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="section-inner">
      <p>&copy; {{ 'now' | date: '%Y' }} Mochirii Cosmetics. All rights reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "summary_text",
      "label": "Summary text",
      "default": "Cleansers, hydrating products, brightening products, and moisturizers for daily skincare routines."
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu"
    }
  ]
}
{% endschema %}
