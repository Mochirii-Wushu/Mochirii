<footer class="site-footer">
  {% assign contact_page = pages['contact'] %}
  {% assign faq_page = pages['faq'] %}
  {% assign about_page = pages['about'] %}
  {% assign ingredients_page = pages['ingredients-standards'] %}
  {% assign accessibility_page = pages['accessibility'] %}
  {% assign support_menu = section.settings.footer_menu %}
  {% if support_menu == blank %}
    {% assign support_menu = linklists['footer'] %}
  {% endif %}
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a class="brand footer-brand" href="{{ routes.root_url }}" aria-label="{{ settings.brand_display_name | default: 'Mochirii Cosmetics' }} skincare storefront home">
        <span class="brand-mark brand-mark--image" aria-hidden="true">
          <img src="{{ 'mochirii-emblem.webp' | asset_url }}" alt="" width="56" height="56" loading="lazy">
        </span>
        <span class="brand-wording">
          <span class="brand-text">{{ settings.brand_display_name | default: 'Mochirii Cosmetics' }}</span>
          <span class="brand-subtext">Skincare</span>
        </span>
      </a>
      <p class="footer-note">{{ section.settings.summary_text | default: settings.footer_summary }}</p>
      {% if contact_page != blank %}<p class="footer-note footer-note--fine">Questions about a product or order? <a href="{{ contact_page.url }}">Contact Mochirii Cosmetics.</a></p>{% endif %}
      <a class="footer-guild-link" href="https://mochirii.com" rel="noopener noreferrer">Visit Mochirii Guild</a>
    </div>

    <div class="footer-nav-groups">
      <nav class="footer-links" aria-label="Footer navigation">
        <h2>Support</h2>
        {% if support_menu != blank and support_menu.links.size > 0 %}
          {% for link in support_menu.links %}
            {% assign is_policy_link = false %}
            {% if shop.shipping_policy != blank and link.url == shop.shipping_policy.url %}
              {% assign is_policy_link = true %}
            {% elsif shop.refund_policy != blank and link.url == shop.refund_policy.url %}
              {% assign is_policy_link = true %}
            {% elsif shop.privacy_policy != blank and link.url == shop.privacy_policy.url %}
              {% assign is_policy_link = true %}
            {% elsif shop.terms_of_service != blank and link.url == shop.terms_of_service.url %}
              {% assign is_policy_link = true %}
            {% endif %}
            {% unless is_policy_link %}
              {% if link.url != blank %}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {% endif %}
            {% endunless %}
          {% endfor %}
        {% else %}
          {% if contact_page != blank %}<a href="{{ contact_page.url }}">Contact</a>{% endif %}
          {% if faq_page != blank %}<a href="{{ faq_page.url }}">Frequently asked questions</a>{% endif %}
          {% if about_page != blank %}<a href="{{ about_page.url }}">About</a>{% endif %}
          {% if ingredients_page != blank %}<a href="{{ ingredients_page.url }}">Ingredients &amp; Standards</a>{% endif %}
          {% if accessibility_page != blank %}<a href="{{ accessibility_page.url }}">Accessibility</a>{% endif %}
        {% endif %}
      </nav>

      <nav class="footer-links" aria-label="Policy navigation">
        <h2>Policies</h2>
        {% if shop.shipping_policy != blank %}
          <a href="{{ shop.shipping_policy.url }}">Shipping</a>
        {% endif %}
        {% if shop.refund_policy != blank %}
          <a href="{{ shop.refund_policy.url }}">Returns</a>
        {% endif %}
        {% if shop.privacy_policy != blank %}
          <a href="{{ shop.privacy_policy.url }}">Privacy</a>
        {% endif %}
        {% if shop.terms_of_service != blank %}
          <a href="{{ shop.terms_of_service.url }}">Terms</a>
        {% endif %}
      </nav>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="section-inner">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ settings.corporate_display_name | default: 'Mochirii Cosmetics' }}. All rights reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "summary_text",
      "label": "Summary text",
      "default": "Skincare for cleansing, hydrating, brightening, and nourishing routines."
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu"
    }
  ]
}
{% endschema %}
