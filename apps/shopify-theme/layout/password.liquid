<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#071610">
    <title>{{ settings.brand_display_name | default: 'Mochirii Cosmetics' }}</title>
    {% render 'seo-meta' %}
    {{ 'mochirii-theme.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --cream-0: {{ settings.background_color | default: '#fffaf0' }};
        --ink-0: {{ settings.text_color | default: '#061610' }};
        --jade-0: {{ settings.accent_color | default: '#1f745f' }};
      }
    </style>
    {{ content_for_header }}
  </head>
  <body class="template-password">
    <main id="MainContent" class="site-main" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
  </body>
</html>
