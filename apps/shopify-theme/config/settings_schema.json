[
  {
    "name": "theme_info",
    "theme_name": "Mochirii Cosmetics",
    "theme_version": "0.4.0",
    "theme_author": "Mochirii Cosmetics",
    "theme_documentation_url": "https://mochirii.com",
    "theme_support_url": "https://mochirii.com"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "text",
        "id": "brand_display_name",
        "label": "Public brand name",
        "default": "Mochirii Cosmetics"
      },
      {
        "type": "text",
        "id": "corporate_display_name",
        "label": "Verified corporate/legal name",
        "info": "Leave blank until the exact legal entity name is approved for public use."
      }
    ]
  },
  {
    "name": "Search and social",
    "settings": [
      {
        "type": "image_picker",
        "id": "social_share_image",
        "label": "Social sharing image"
      },
      {
        "type": "textarea",
        "id": "default_meta_description",
        "label": "Default search description",
        "default": "Shop Mochirii Cosmetics skincare by routine step, with ingredients, directions, skin types, and product details for every formula."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background",
        "default": "#f7f8f5"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text",
        "default": "#13231d"
      },
      {
        "type": "color",
        "id": "accent_color",
        "label": "Accent",
        "default": "#1f6b58"
      }
    ]
  },
  {
    "name": "Storefront copy",
    "settings": [
      {
        "type": "text",
        "id": "storefront_mode_text",
        "label": "Storefront mode text",
        "default": "Skincare, step by step"
      },
      {
        "type": "text",
        "id": "empty_catalog_heading",
        "label": "Empty catalog heading",
        "default": "No products match these filters."
      },
      {
        "type": "textarea",
        "id": "empty_catalog_body",
        "label": "Empty catalog body",
        "default": "Clear a filter or browse the full collection."
      },
      {
        "type": "textarea",
        "id": "footer_summary",
        "label": "Footer summary",
        "default": "Skincare organized by routine step, skin type, and formula."
      }
    ]
  },
  {
    "name": "Launch controls",
    "settings": [
      {
        "type": "checkbox",
        "id": "product_publication_approved",
        "label": "Publish approved product information",
        "info": "Enable only after the separate product, asset, regulatory, and legal review is complete.",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "checkout_enabled",
        "label": "Enable approved commerce",
        "info": "Effective only when product publication is also approved. Enable only after the separate commerce launch approval.",
        "default": false
      }
    ]
  }
]
