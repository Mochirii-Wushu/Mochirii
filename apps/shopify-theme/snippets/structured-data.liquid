<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ settings.brand_display_name | default: 'Mochirii Cosmetics' | json }},
    "url": {{ shop.url | json }}{% if settings.social_share_image != blank %},
    "logo": {{ settings.social_share_image | image_url: width: 512 | json }}{% endif %}
  }
</script>

{% if request.page_type == 'product' %}
  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>
{% endif %}

{% unless request.page_type == 'index' %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ shop.url | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ page_title | json }},
          "item": {{ canonical_url | json }}
        }
      ]
    }
  </script>
{% endunless %}
