{% assign navigation_id = navigation_id | default: 'primary-navigation' %}
<ul class="site-nav__list" role="list">
  {% if primary_menu != blank and primary_menu.links.size > 0 %}
    {% for link in primary_menu.links %}
      <li class="site-nav__item{% if link.links.size > 0 %} site-nav__item--has-children{% endif %}">
        {% capture submenu_id %}{{ navigation_id }}-submenu-{{ forloop.index }}{% endcapture %}
        <span class="site-nav__link-row">
          <a href="{{ link.url }}" {% if link.current %}aria-current="page"{% endif %}>{{ link.title }}</a>
          {% if link.links.size > 0 %}
            <button
              class="site-nav__toggle"
              type="button"
              aria-expanded="false"
              aria-controls="{{ submenu_id }}"
              aria-label="Toggle {{ link.title | escape }} submenu"
              data-navigation-toggle
            ><span aria-hidden="true">&#9662;</span></button>
          {% endif %}
        </span>
        {% if link.links.size > 0 %}
          <ul id="{{ submenu_id }}" class="site-nav__sublist" role="list" aria-label="{{ link.title | escape }} submenu">
            {% for child_link in link.links %}
              <li class="site-nav__item{% if child_link.links.size > 0 %} site-nav__item--has-children{% endif %}">
                {% capture child_submenu_id %}{{ navigation_id }}-submenu-{{ forloop.parentloop.index }}-{{ forloop.index }}{% endcapture %}
                <span class="site-nav__link-row">
                  <a href="{{ child_link.url }}" {% if child_link.current %}aria-current="page"{% endif %}>{{ child_link.title }}</a>
                  {% if child_link.links.size > 0 %}
                    <button
                      class="site-nav__toggle"
                      type="button"
                      aria-expanded="false"
                      aria-controls="{{ child_submenu_id }}"
                      aria-label="Toggle {{ child_link.title | escape }} submenu"
                      data-navigation-toggle
                    ><span aria-hidden="true">&#9656;</span></button>
                  {% endif %}
                </span>
                {% if child_link.links.size > 0 %}
                  <ul id="{{ child_submenu_id }}" class="site-nav__sublist site-nav__sublist--nested" role="list" aria-label="{{ child_link.title | escape }} submenu">
                    {% for grandchild_link in child_link.links %}
                      <li class="site-nav__item">
                        <span class="site-nav__link-row">
                          <a href="{{ grandchild_link.url }}" {% if grandchild_link.current %}aria-current="page"{% endif %}>{{ grandchild_link.title }}</a>
                        </span>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  {% else %}
    <li class="site-nav__item"><span class="site-nav__link-row"><a href="{{ catalog_url }}" {% if template.name == 'collection' or template.name == 'product' %}aria-current="page"{% endif %}>Shop</a></span></li>
    <li class="site-nav__item"><span class="site-nav__link-row"><a href="{{ product_type_url }}">Product type</a></span></li>
    <li class="site-nav__item"><span class="site-nav__link-row"><a href="{{ skin_needs_url }}">Skin needs</a></span></li>
    <li class="site-nav__item"><span class="site-nav__link-row"><a href="{{ routine_url }}" {% if template.name == 'list-collections' %}aria-current="page"{% endif %}>Routine</a></span></li>
    {% if about_url != blank %}<li class="site-nav__item"><span class="site-nav__link-row"><a href="{{ about_url }}" {% if request.path == about_url %}aria-current="page"{% endif %}>About</a></span></li>{% endif %}
    {% if help_url != blank %}<li class="site-nav__item"><span class="site-nav__link-row"><a href="{{ help_url }}" {% if request.path == help_url %}aria-current="page"{% endif %}>Help</a></span></li>{% endif %}
  {% endif %}
  <li class="site-nav__item"><span class="site-nav__link-row"><a href="{{ routes.search_url }}" {% if template.name == 'search' %}aria-current="page"{% endif %}>Search</a></span></li>
  <li class="site-nav__item">
    <span class="site-nav__link-row">
      <a class="site-nav__cart" href="{{ routes.cart_url }}" aria-label="Cart{% if cart.item_count > 0 %}, {{ cart.item_count }} items{% endif %}" {% if template.name == 'cart' %}aria-current="page"{% endif %}>
        Cart <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </span>
  </li>
</ul>
