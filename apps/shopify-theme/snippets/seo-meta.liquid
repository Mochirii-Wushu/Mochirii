{% liquid
  assign storefront_name = settings.brand_display_name | default: 'Mochirii Cosmetics'
  assign seo_title = seo_title_override | default: page_title | default: storefront_name
  assign seo_title = seo_title | replace: '&amp;', '&'
  assign seo_description = seo_description_override | default: page_description | default: settings.default_meta_description | strip_html | strip_newlines | escape
  assign social_image = page_image
  if social_image == blank and request.page_type == 'product'
    assign social_image = product.featured_media.preview_image
  elsif social_image == blank and request.page_type == 'collection'
    assign social_image = collection.image
  endif
  if social_image == blank
    assign social_image = settings.social_share_image
  endif
  if social_image == blank
    assign social_image = collections['mochirii-cosmetics'].products.first.featured_media.preview_image
  endif
  if social_image != blank
    assign social_image_width = social_image.width | at_most: 1200
    assign social_image_height = social_image_width | divided_by: social_image.aspect_ratio | round
  endif
%}

<link rel="canonical" href="{{ canonical_url }}">
<meta property="og:site_name" content="{{ storefront_name | escape }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ seo_title | escape }}">
<meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
{% if seo_description != blank %}
  <meta property="og:description" content="{{ seo_description }}">
{% endif %}
{% if social_image != blank %}
  <meta property="og:image" content="{{ social_image | image_url: width: social_image_width }}">
  <meta property="og:image:width" content="{{ social_image_width }}">
  <meta property="og:image:height" content="{{ social_image_height }}">
{% endif %}
<meta name="twitter:card" content="{% if social_image != blank %}summary_large_image{% else %}summary{% endif %}">
<meta name="twitter:title" content="{{ seo_title | escape }}">
{% if seo_description != blank %}
  <meta name="twitter:description" content="{{ seo_description }}">
{% endif %}
{% if social_image != blank %}
  <meta name="twitter:image" content="{{ social_image | image_url: width: social_image_width }}">
{% endif %}
