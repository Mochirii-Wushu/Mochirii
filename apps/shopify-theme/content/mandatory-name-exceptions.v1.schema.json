{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mochirii.com/contracts/mandatory-name-exceptions.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "revision",
    "locale",
    "brand",
    "status",
    "required_rendered_route_categories",
    "rendered_review",
    "entries"
  ],
  "properties": {
    "$schema": { "const": "./mandatory-name-exceptions.v1.schema.json" },
    "schema_version": { "const": 1 },
    "revision": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]+$" },
    "locale": { "const": "en-US" },
    "brand": { "const": "Mochirii Cosmetics" },
    "status": { "enum": ["pending-review", "reviewed"] },
    "required_rendered_route_categories": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "rendered_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewer",
        "review_date",
        "reviewed_route_categories"
      ],
      "properties": {
        "status": { "enum": ["pending", "reviewed"] },
        "reviewer": { "type": ["string", "null"] },
        "review_date": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "format": "date" }
          ]
        },
        "reviewed_route_categories": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "route",
        "exact_name",
        "legal_or_contractual_reason",
        "exact_approved_wording",
        "reviewer",
        "review_date"
      ],
      "properties": {
        "surface": { "type": "string", "minLength": 1 },
        "route": { "type": "string", "minLength": 1 },
        "exact_name": { "type": "string", "minLength": 1 },
        "legal_or_contractual_reason": { "type": "string", "minLength": 1 },
        "exact_approved_wording": { "type": "string", "minLength": 1 },
        "reviewer": { "type": "string", "minLength": 1 },
        "review_date": { "type": "string", "format": "date" }
      }
    }
  }
}
