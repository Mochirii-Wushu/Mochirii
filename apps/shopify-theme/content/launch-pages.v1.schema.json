{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mochirii.com/contracts/launch-pages.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "revision",
    "locale",
    "brand",
    "status",
    "lifecycle",
    "pages"
  ],
  "properties": {
    "$schema": { "const": "./launch-pages.v1.schema.json" },
    "schema_version": { "const": 1 },
    "revision": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]+$" },
    "locale": { "const": "en-US" },
    "brand": { "const": "Mochirii Cosmetics" },
    "status": {
      "enum": [
        "prepared-not-applied",
        "applied-readback-verified"
      ]
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preparation_status",
        "application_status",
        "readback_status",
        "provider_write_authority"
      ],
      "properties": {
        "preparation_status": { "const": "prepared" },
        "application_status": { "enum": ["not-applied", "applied"] },
        "readback_status": { "enum": ["not-verified", "verified"] },
        "provider_write_authority": { "const": false }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/page" }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handle",
        "title",
        "body_html",
        "seo_title",
        "seo_description"
      ],
      "properties": {
        "handle": {
          "enum": [
            "faq",
            "ingredients-standards",
            "accessibility"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "body_html": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "seo_title": { "type": "string", "minLength": 1, "maxLength": 59 },
        "seo_description": { "type": "string", "minLength": 70, "maxLength": 159 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "handle": { "const": "faq" } },
            "required": ["handle"]
          },
          "then": {
            "properties": {
              "body_html": {
                "allOf": [
                  { "pattern": "href=\\\"/policies/shipping-policy\\\"" },
                  { "pattern": "href=\\\"/policies/refund-policy\\\"" }
                ]
              }
            }
          }
        }
      ]
    }
  }
}
